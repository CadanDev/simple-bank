RewriteEngine On

# If the request is for an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise rewrite to index.php (preserve query string)
RewriteRule ^ index.php [QSA,L]
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /ebanx/api/

    # garante que request pra arquivos reais sejam entregues
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # todas as rotas REST vão para index.php
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>